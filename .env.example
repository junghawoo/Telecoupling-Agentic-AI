# Telecoupling AI - Environment Configuration
# Copy this file to .env and fill in your values

# LLM Provider: "purdue" or "gemini"
LLM_PROVIDER=purdue

# Purdue GenAI Studio (required if LLM_PROVIDER=purdue)
PURDUE_API_KEY=your-purdue-api-key-here
PURDUE_BASE_URL=https://genai.rcac.purdue.edu/api
PURDUE_MODEL=llama4:latest

# Google Gemini (required if LLM_PROVIDER=gemini)
GEMINI_API_KEY=your-gemini-api-key-here
GEMINI_MODEL=gemini-2.0-flash

# MCP Server Ports (defaults shown)
INVEST_MCP_PORT=54320
QGIS_MCP_PORT=54321

# Data Paths (relative to backend/)
INVEST_SAMPLE_DATA_DIR=./data/sample-inputs
INVEST_OUTPUT_DIR=./data/outputs
WORKSPACE_DIR=./data/outputs
UPLOAD_DIR=./data/uploads

# Logging
LOG_LEVEL=INFO
