# invest-mcp server configuration
# ─────────────────────────────────────────────────────
# Copy this file to .env and fill in the values.
# All variables are optional — defaults are shown.

# ── Server ────────────────────────────────────────────
# Port the MCP server listens on (SSE transport)
INVEST_MCP_PORT=54320

# Log verbosity: DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO

# ── Data Paths ────────────────────────────────────────
# Where model output workspaces are created
INVEST_OUTPUT_DIR=./data/outputs

# Directory containing InVEST sample input data
# Run:  python download_sample_data.py   (at repo root) to populate
INVEST_SAMPLE_DATA_DIR=./data/sample-inputs

# ── Crop Production Models ────────────────────────────
# Path to the InVEST model-data directory.
# Required only for run_crop_production_percentile and run_crop_production_regression.
# Download: https://storage.googleapis.com/releases.naturalcapitalproject.org/invest/3.14.0/InVEST_3.14.0_model_data.zip
MODEL_DATA_PATH=
