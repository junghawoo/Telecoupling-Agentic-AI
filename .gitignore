# ── Python ────────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*.pyo
.Python

# ── Virtual environments ───────────────────────────────────────────────────────
.venv/
venv/
env/

# ── Secrets ───────────────────────────────────────────────────────────────────
.env
.env.*
!.env.example

# ── Sample data (530MB — download via download_sample_data.py) ───────────────
backend/data/sample-inputs/*
